#!/bin/sh
# Commit sonrasi otomatik GitHub'a gonder (origin, mevcut dal).
# Kurulum: npm run setup-hooks (bir kez)

branch=$(git symbolic-ref --short HEAD 2>/dev/null) || exit 0

if ! git push origin "$branch"; then
  printf '%s\n' "post-commit: git push basarisiz (ag veya kimlik dogrulama). Commit yerelde kayitli."
fi
